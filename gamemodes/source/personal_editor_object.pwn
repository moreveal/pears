stock ClearPeoInfo(playerid) // 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇
{
    peoInfo[playerid][peoNewid] = 0;
    peoInfo[playerid][peoLoaded] = false;
    peoInfo[playerid][peoQuanUpdates] = 0;
    peoInfo[playerid][peoQuanObjects] = 0;
    peoInfo[playerid][peoCreatorId] = 0;
    peoInfo[playerid][peoStatusLoad] = false;
    peoInfo[playerid][peoPriceInterior] = 0;
    peoInfo[playerid][peoPublicationStatus] = 0;
    peoInfo[playerid][peoObjectLabelStatus] = false;
    return 1;
}

stock DestroyPeoInterior(playerid) // 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 (锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇)
{
    for(new i = 0; i < MAX_OBJECT_INT; i++)
    {
        if(peoInfo[playerid][peoModel][i] > 0) 
        {
            if(IsValidDynamicObject(peoInfo[playerid][peoObject][i])) 
            {
                if(i > 0) DestroyDynamic3DTextLabel(peoInfo[playerid][peoObjectLabel][i]);
                DestroyDynamicObject(peoInfo[playerid][peoObject][i]);
            }
            peoInfo[playerid][peoModel][i] = 0;
            for(new t = 0; t < MAX_TEXTURES_ON_OBJECTS; t++) peoTexture[playerid][i][t] = 0;
        }
    }
    return 1;
}

CMD:loadeditor(playerid) // 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇
{
    if(PlayerInfo[playerid][pSoska] <= 0)
    {
	    // if(!IsPlayerInRangeOfPoint(playerid, 2.0, 228.0, 228.0, 228.0)) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇 锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");
        if(PursuitTime[playerid] >= 1) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");
        if(howstun(playerid) || HealthAC[playerid] <= 0) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");
    }
    if(peoInfo[playerid][peoInEditor]) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇 锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");

    if(GetPlayerState(playerid) == PLAYER_STATE_SPECTATING) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");
    if(setting_pos_draw[playerid] > 0 || setting_size_draw[playerid] > 0) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");

    if(OnlineInfo[playerid][oShowInterface] == 1) CloseFrisk(playerid), CancelSelectTextDraw(playerid); // 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇
    else if(OnlineInfo[playerid][oShowInterface] == 2) CloseSmartfon(playerid), CancelSelectTextDraw(playerid); // 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇

    // 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇, 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇
    GetPlayerPos(playerid, SpX[playerid], SpY[playerid], SpZ[playerid]);
    GetPlayerFacingAngle(playerid, SpA[playerid]);
    SpInt[playerid] = GetPlayerInterior(playerid);
