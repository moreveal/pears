    else if(typeProperty == 1) format(store,sizeof(store),"{99ff66}锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 {ff9000}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇 %d", propId);
