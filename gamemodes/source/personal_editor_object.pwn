stock SetObjectPosPersonalEditor(playerid, slotId, Float:pos, posId)
{
    if(!peoInfo[playerid][peoInEditor]) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇 锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 [ /loadeditor ]");
    if(gRedakt[playerid] != 0) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");
    if(peoInfo[playerid][peoStatusLoad]) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");
    new world = GetPlayerVirtualWorld(playerid);
    new peoId = world-4000;
    if(peoId != playerid) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");
    if(peoInfo[peoId][peoModel][0] == 0) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");

    if(slotId <= 0 || slotId >= MAX_OBJECT_INT) return format(store,sizeof(store),"{FF6347}ID 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 1 锌褩袇 锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 %d", MAX_OBJECT_INT), ErrorMessage(playerid, store);
    if(peoInfo[peoId][peoModel][slotId] == 0) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇 ID 锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");

    if(posId >= 3) // 锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇
    {
        if(pos < -360.0 || pos > 360.0) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 -360.0 锌褩袇 锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 360.0");
    }
    else // 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇
    {
        if(pos < -200.0 || pos > 200.0) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 -200.0 锌褩袇 锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 200.0");
        new Float:maxDistFromInterior = GetDistancePoint(1387.4436,-16.2143,1000.8868,peoInfo[playerid][peoX][slotId]+pos,peoInfo[playerid][peoY][slotId]+pos,peoInfo[playerid][peoZ][slotId]+pos);
        if(maxDistFromInterior >= 200.0) return ErrorMessage(playerid, "{FF6347}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇 200 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");
    }

    if(!IsValidDynamicObject(peoInfo[peoId][peoObject][slotId])) return ErrorMessage(playerid, "{FF6347}DynamicObject 锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 ID 锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");

    if(posId == 0) peoInfo[playerid][peoX][slotId] += pos; // x
    else if(posId == 1) peoInfo[playerid][peoY][slotId] += pos; // y
    else if(posId == 2) peoInfo[playerid][peoZ][slotId] += pos; // z
    else if(posId == 3) peoInfo[playerid][peoRX][slotId] += pos; // rx
    else if(posId == 4) peoInfo[playerid][peoRY][slotId] += pos; // ry
    else if(posId == 5) peoInfo[playerid][peoRZ][slotId] += pos; // rz

    SetDynamicObjectPos(peoInfo[peoId][peoObject][slotId], peoInfo[playerid][peoX][slotId], peoInfo[playerid][peoY][slotId], peoInfo[playerid][peoZ][slotId]);
    SetDynamicObjectRot(peoInfo[peoId][peoObject][slotId], peoInfo[playerid][peoRX][slotId], peoInfo[playerid][peoRY][slotId], peoInfo[playerid][peoRZ][slotId]);
    peoInfo[playerid][peoQuanUpdates] ++;

    if(peoInfo[playerid][peoObjectLabelStatus]) update3dtextLabelPos(playerid, slotId);
    return 1;
}

