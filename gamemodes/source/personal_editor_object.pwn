    format(line,sizeof(line),"\n{666666}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 {A86CFB}>> \t "), strcat(lines,line);
    ShowDialog(playerid,1292,DIALOG_STYLE_TABLIST_HEADERS,"{A86CFB}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇",lines,"锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇","锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇");
