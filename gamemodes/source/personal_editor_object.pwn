stock showDialogPersonalEditor(playerid, targetid)
{
    format(lines,sizeof(lines),""); // 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 Lines

    format(line,sizeof(line),"锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇: %d \t ", peoInfo[targetid][peoQuanUpdates]), strcat(lines,line);

    format(line,sizeof(line),"\n{A86CFB}* {cccccc}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 >> \t {cccccc}[ %d ]", peoInfo[targetid][peoQuanObjects]), strcat(lines,line);
    format(line,sizeof(line),"\n{A86CFB}* {cccccc}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 \t "), strcat(lines,line);
    format(line,sizeof(line),"\n{A86CFB}* {cccccc}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 \t {FF9000}%s", peoInfo[targetid][peoName]), strcat(lines,line);
    format(line,sizeof(line),"\n{A86CFB}* {cccccc}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 \t {99ff66}%d$", peoInfo[targetid][peoPriceInterior]), strcat(lines,line);

    if(!peoInfo[targetid][peoObjectLabelStatus]) format(line,sizeof(line),"\n{A86CFB}* {cccccc}3D Text Label \t {FF6347}[ Off ]"), strcat(lines,line);
    else format(line,sizeof(line),"\n{A86CFB}* {cccccc}3D Text Label \t {99ff66}[ On ]"), strcat(lines,line);

    if(!peoInfo[targetid][peoLoaded]) format(line,sizeof(line),"\n{A86CFB}* {cccccc}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 \t "), strcat(lines,line);
    else format(line,sizeof(line),"\n{A86CFB}* {cccccc}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 \t {99ff66}[ 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 ]"), strcat(lines,line);

    format(line,sizeof(line),"\n{A86CFB}* {cccccc}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 \t "), strcat(lines,line);

    format(line,sizeof(line),"\n{A86CFB}* {99ff66}锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 \t "), strcat(lines,line);
