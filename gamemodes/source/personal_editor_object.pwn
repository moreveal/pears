    if(params[0] <= 0 || params[0] > 100000000) return SendClientMessage(playerid, COLOR_GREY, "[ 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 ]: 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 1 锌褩袇 锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 100.000.000$");

