    DP[0][playerid] = 1; // 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇
