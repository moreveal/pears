stock showDialogAllObjectsPeo(playerid, targetid)
{
	PlayerPlaySound(playerid,40405,0,0,0);

    format(lines,sizeof(lines),""); // 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 Lines
    format(line,sizeof(line),"ID ModelID 锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇锌褩袇 \t 锌褩袇锌褩袇锌褩袇. 锌褩袇锌褩袇锌褩袇锌褩袇"), strcat(lines,line);
 	for(new i = 0; i < MAX_OBJECT_INT; i++)
