// Если каркас требует второй объект
stock IsASecondObject(model)
{
	if(model == 12169) return 12170; // ID объекта, который привязан к планировке (исключение для этой шляпы)
	return 0;
}

// Сколько объектов используется у планировки
stock IsAQuanInterior(model)
{
	if(model == 14536) return 8; // У этой планировки 8 объектов
	else if(model == 12169) return 2; // У этой планировки 2 объекта
	return 1; // Все остальные 1 объект
}



// Проверка на то, что объект является рюкзаком
stock IsABackPack(AksId)
{
    if(AksId == 12104 || (AksId >= 12114 && AksId <= 12133) || AksId == 12171 || AksId == 12172 || AksId == 12137 
    || (AksId >= 12175 && AksId <= 12195) || AksId == 12331 || AksId == 12348 || (AksId >= 12367 && AksId <= 12373) 
    || AksId == 12407 || (AksId >= 12473 && AksId <= 12478) || GetBustAksType(AksId) == 1) return true;
    else return false;
}


