stock DynamicPickupParking()
{
	for(new i = 0; i < sizeof(ParkingPickup); i++)
    {
        CreateDynamicPickup(2485, 1, ParkingPickup[i][0],ParkingPickup[i][1],ParkingPickup[i][2], 0, 0);
        CreateDynamic3DTextLabel("{ff9000}Парковка {444444}[Зона парковки 10 метров]\n\nCAPS LOCK (Гудок) {cccccc}- припарковать",-1,ParkingPickup[i][0],ParkingPickup[i][1],ParkingPickup[i][2],7.0,INVALID_PLAYER_ID,INVALID_VEHICLE_ID,1,0,0);
    }
	return 1;
}

stock IsAServiceVehicleSop(playerid)
{
	new shopId;
	if(IsPlayerInRangeOfPoint(playerid,2.0,950.6496,-1701.0853,13.5510)) shopId = 183;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,1210.9694,-918.3889,43.0305)) shopId = 184;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,1783.9803,-1792.3568,13.5968)) shopId = 185;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,-2284.5659,-170.5629,35.3203)) shopId = 186;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,-2199.5869,967.6679,80.0000)) shopId = 187;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,-2552.6299,666.9107,27.8125)) shopId = 188;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,1540.4404,984.2271,10.8590)) shopId = 189;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,1627.8523,2200.0857,10.8692)) shopId = 190;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,2645.2419,1213.7122,10.8530)) shopId = 191;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,-1292.6141,2698.0901,50.0980)) shopId = 192;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,1916.2583,-2223.2319,13.6086)) shopId = 193;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,-1303.3726,-482.8040,14.2233)) shopId = 194;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,1340.1633,1274.3285,10.8711)) shopId = 195;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,2746.8845,-2339.0249,13.6670)) shopId = 197;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,-1510.0084,685.4597,7.2423)) shopId = 198;
	else if(IsPlayerInRangeOfPoint(playerid,2.0,2259.4963,549.9659,7.8012)) shopId = 199;
	DP[4][playerid] = shopId;
	return shopId;
}

stock ServiceVehicleShop(playerid)
{
	new b = DP[4][playerid];
	new line[80],lines[240];
	format(line,sizeof(line),"{cccccc}Товар\tСтоимость\tНаличие"), strcat(lines,line);

	new i = 0;
	List[0][playerid] = i;
	format(line,sizeof(line),"\n{cccccc}%s \t {99ff66}%d$ \t {444444}%d", GetNameThing(0, BizzInfo[b][bProduct][i], BizzInfo[b][bTypeProduct][i], 0), BizzInfo[b][bPrice][i], BizzInfo[b][bItem][i]), strcat(lines,line);
	if(b <= 192)
	{
		i = 6;
		List[1][playerid] = i;
		format(line,sizeof(line),"\n{cccccc}%s \t {99ff66}%d$ \t {444444}%d", GetNameThing(0, BizzInfo[b][bProduct][i], BizzInfo[b][bTypeProduct][i], 0), BizzInfo[b][bPrice][i], BizzInfo[b][bItem][i]), strcat(lines,line);
	}

	ShowDialog(playerid,633,DIALOG_STYLE_TABLIST_HEADERS,"{ff9000}Магазин Сервиса",lines,"Выбор","Отмена");
	PlayerPlaySound(playerid,40405,0,0,0);
	return 1;
}

stock CheckService(playerid, model)
{
	if(IsPlayerInRangeOfPoint(playerid,2.0,1916.656616, -2218.220703, 14.038616) || IsPlayerInRangeOfPoint(playerid,2.0,-1305.269653, -478.098663, 14.663259)
	|| IsPlayerInRangeOfPoint(playerid,2.0,1335.117919, 1274.780395, 11.271109))
	{
		if(!IsAPlane(model))
		{
			ErrorMessage(playerid, "{FF6347}В этом сервисе обслуживается только авиатранспорт");
			return 0;
		}
	}
	else if(IsPlayerInRangeOfPoint(playerid,2.0,2679.039062, -2318.251953, 3.419997) || IsPlayerInRangeOfPoint(playerid,2.0,-1476.260986, 694.360717, 1.947611)
	|| IsPlayerInRangeOfPoint(playerid,2.0,2299.353027, 523.798095, 2.214375))
	{
		if(!IsABoat(model))
		{
			ErrorMessage(playerid, "{FF6347}В этом сервисе обслуживаются только катера и лодки");
			return 0;
		}
	}
	else if(IsPlayerInRangeOfPoint(playerid,2.0,950.388854, -1706.210693, 13.973308) || IsPlayerInRangeOfPoint(playerid,2.0,1210.486572, -913.241516, 43.370220)
	|| IsPlayerInRangeOfPoint(playerid,2.0,1784.199951, -1787.146240, 14.016786) || IsPlayerInRangeOfPoint(playerid,2.0,-2284.408935, -165.393066, 35.730281)
	|| IsPlayerInRangeOfPoint(playerid,2.0,-2199.331298, 972.793395, 80.419982) || IsPlayerInRangeOfPoint(playerid,2.0,-2557.822509, 667.154357, 28.252510)
	|| IsPlayerInRangeOfPoint(playerid,2.0,1540.683349, 989.364868, 11.258984) || IsPlayerInRangeOfPoint(playerid,2.0,1633.046630, 2199.819824, 11.279161)
	|| IsPlayerInRangeOfPoint(playerid,2.0,2645.016845, 1208.508178, 11.252993) || IsPlayerInRangeOfPoint(playerid,2.0,-1288.076782, 2700.420410, 50.498001))
	{
		if(IsABoat(model)
		|| IsAPlane(model))
		{
			ErrorMessage(playerid, "{FF6347}В этом сервисе обслуживаются автомобили и мототранспорт");
			return 0;
		}
	}
	else
	{
		ErrorMessage(playerid, "{FF6347}Ошибка! Вы далеко от терминала обслуживания транспорта");
		return 0;
	}
	return 1;
}

stock IsACallVehicle(playerid)
{
	if(IsPlayerInRangeOfPoint(playerid,2.0,950.388854, -1706.210693, 13.973308) || IsPlayerInRangeOfPoint(playerid,2.0,1210.486572, -913.241516, 43.370220)
	|| IsPlayerInRangeOfPoint(playerid,2.0,1784.199951, -1787.146240, 14.016786) || IsPlayerInRangeOfPoint(playerid,2.0,-2284.408935, -165.393066, 35.730281)
