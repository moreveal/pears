CMD:entertrain(playerid)
{
	if(PlayerInfo[playerid][pSoska] <= 0) return 1;
	EnterTrain(playerid, 1);
	return 1;
}

stock EnterTrain(playerid, stat)
{
	new current_tick = GetTickCount();
    new interval = GetTickDiff(current_tick, Afclick[playerid]);
    if(interval < 1000)
	{
		if(stat == 0) ClearAnimations(playerid), SetCameraBehindPlayer(playerid);
		ErrorMessage(playerid, "{FF6347}Пожалуйста... не флудите");
		return 0;
	}
	Afclick[playerid] = current_tick;

	/*if(TrainGear >= 5 && stat == 0)
	{
		ClearAnimations(playerid);
		ErrorMessage(playerid, "{FF6347}Вы не можете сесть в поезд на высокой скорости");
		SetCameraBehindPlayer(playerid);
		return 0;
	}*/
	if(fraction(playerid) != 3 && stat == 0)
	{
		ClearAnimations(playerid);
		ErrorMessage(playerid, "{FF6347}Вы не состоите в NGSA");
		SetCameraBehindPlayer(playerid);
		return 0;
	}

	keep(playerid);
	S_SetPlayerVirtualWorld(playerid,180,179), SetPlayerInterior(playerid,179);
	if(EnterTrainPos == 0) PPSetPlayerPos(playerid, 1304.9014,1604.4469,19.8963), SetPlayerFacingAngle(playerid, 90.5205), EnterTrainPos = 1;
	else if(EnterTrainPos == 1) PPSetPlayerPos(playerid, 1304.4021,1604.2426,19.8963), SetPlayerFacingAngle(playerid, 112.7673), EnterTrainPos = 2;
	else if(EnterTrainPos == 2) PPSetPlayerPos(playerid, 1304.7849,1603.6268,19.8963), SetPlayerFacingAngle(playerid, 138.7743), EnterTrainPos = 0;
	SetCameraBehindPlayer(playerid);
	return 1;
}

stock ExitTrain(playerid)
{
	//if(TrainGear >= 6) return ErrorMessage(playerid, "{FF6347}Вы не можете выйти из поезда на высокой скорости\n{cccccc}Дождитесь остановки на ближайшей станции");
	new Float:pos[4];
	new Float:offset;
	GetVehiclePos(train, pos[0], pos[1], pos[2]);
	//pos[3] = TrainRoad[TrainRoadID][TrainRoad_A];
	GetVehicleZAngle(train, pos[3]);

	// Смещаем координаты вправо
	pos[0] -= (-2.2 * floatsin(-pos[3]+90, degrees));
    pos[1] -= (-2.2 * floatcos(-pos[3]+90, degrees));

	if(ExitTrainPos == 0) offset = -3.0, ExitTrainPos = 1; // Смещаем назад на 3 метра
	else if(ExitTrainPos == 1) offset = -1.0, ExitTrainPos = 2; // Смещаем назад на 1 метра
	else if(ExitTrainPos == 2) offset = 1.0, ExitTrainPos = 3; // Смещаем вперёд на 1 метр
	else if(ExitTrainPos == 3) offset = 3.0, ExitTrainPos = 4; // Смещаем вперёд на 3 метра
	else if(ExitTrainPos == 4) offset = 5.0, ExitTrainPos = 0; // Смещаем вперёд на 5 метров

	pos[0] -= (offset * floatsin(-pos[3]+180, degrees));
    pos[1] -= (offset * floatcos(-pos[3]+180, degrees));

	keep(playerid);
	S_SetPlayerVirtualWorld(playerid,0,0), SetPlayerInterior(playerid,0);
	PPSetPlayerPos(playerid, pos[0], pos[1], pos[2]-1.0);
	SetPlayerFacingAngle(playerid, pos[3]);
	SetCameraBehindPlayer(playerid);
	return 1;
}

stock OpenWindowTrain(playerid)
{
	if(OnlineInfo[playerid][oWindowTrain] > 0) return 1;
	if(howstun(playerid) || HealthAC[playerid] <= 0) return ErrorMessage(playerid, "{FF6347}Вашему персонажу плохо");

	new current_tick = GetTickCount();
    new interval = GetTickDiff(current_tick, Afclick[playerid]);
    if(interval < 1000) return ErrorMessage(playerid, "{FF6347}Пожалуйста... не флудите");
	Afclick[playerid] = current_tick;

	GetPlayerPos(playerid, SpX[playerid], SpY[playerid], SpZ[playerid]); 
	GetPlayerFacingAngle(playerid, SpA[playerid]);
	SpInt[playerid] = GetPlayerInterior(playerid);
	SpWorld[playerid] = GetPlayerVirtualWorld(playerid);

	OnlineInfo[playerid][oWindowTrain] = train;
	S_SetPlayerVirtualWorld(playerid, 0, 0);
	SetPlayerInterior(playerid, 0);

	new Float:x, Float:y, Float:z;
	GetVehiclePos(train, x, y, z);
	PPOpenSpectating(playerid, x, y, z);
	PlayerSpectateVehicle(playerid, train);
	TextDrawShowForPlayer(playerid, MindDraw[3]), PlayerTextDrawSetString(playerid, HintButton, "ENTER"), PlayerTextDrawShow(playerid, HintButton);

	SetTimerEx("ResetSpecTrain", 2000, false, "d", playerid);
	return 1;
}

function ResetSpecTrain(playerid) // Перезапускаем слежку, в случае багули
{
	if(OnlineInfo[playerid][oWindowTrain] != train) return 1;
	PlayerSpectateVehicle(playerid, train);
	return 1;
}

stock ExitWindowTrain(playerid)
{
	HidePlayerDialog(playerid);
	TextDrawHideForPlayer(playerid, Chernifon);
	TextDrawHideForPlayer(playerid, MindDraw[3]), PlayerTextDrawHide(playerid, HintButton);
	SetPosa[playerid] = 1;
	OnlineInfo[playerid][oWindowTrain] = 0;
    PPExitSpectating(playerid);
	return 1;
}

