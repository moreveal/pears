#define MAX_ACCESSORY 1000 // Ěŕęńčěŕëüíîĺ ęîëč÷ĺńňâî ŕęńĺńńóŕđîâ äë˙ čăđîęîâ

enum acInfo
{
	acID, // ID Â áŕçĺ äŕííűő
	acModel, // Ěîäĺëü Ŕęńĺńńóŕđŕ
	acName[34], // Íŕçâŕíčĺ ŕęńĺńńóŕđŕ
	acPrice, // Ăîń öĺíŕ ŕęńĺńńóŕđŕ
	acStatus, // Ńňŕňóń ŕęńĺńńóŕđŕ, ŕęňčâĺí îí čëč íĺň
	acBone, // Ęîńňü (Ęóäŕ ęđĺďčňń˙ ýňîň ŕęńĺńńóŕđ)
	Float:acX,
	Float:acY,
	Float:acZ,
	Float:acrX,
	Float:acrY,
	Float:acrZ,
	Float:acsX,
	Float:acsY,
	Float:acsZ,
	bool:acUpdate, // Ńňŕňóń ńîőđŕíĺíč˙ â áŕçó (đŕç â ěčíóňó ďđîâĺđęŕ)
	bool:acMysqlCheck // Çŕďđĺň íŕ ďîâňîđíűé çŕďđîń â áŕçó, ďîęŕ îň ďđĺäűäóůĺăî íĺ ďđčřĺë îňâĺň
};
new AccessoryInfo[MAX_ACCESSORY][acInfo];
new AccessoryQuan;

new AccessoryEditSkin;

new boneName[][] = // Íŕçâŕíč˙ ęđĺďëĺíčé ŕęńĺńńóŕđŕ ę ęîńň˙ě
{
    "Ăîëîâŕ", "Ńďčíŕ", "Ăîëîâŕ", "Ëĺâîĺ ďëĺ÷î", "Ďđŕâîĺ ďëĺ÷î", "Ëĺâŕ˙ đóęŕ", "Ďđŕâŕ˙ đóęŕ", "Ëĺâîĺ áĺäđî", "Ďđŕâîĺ áĺäđî", "Ëĺâŕ˙ íîăŕ",
    "Ďđŕâŕ˙ íîăŕ", "Ďđŕâŕ˙ čęđŕ", "Ëĺâŕ˙ čęđŕ", "Ëĺâîĺ ďđĺäďëĺ÷üĺ", "Ďđŕâîĺ ďđĺäďëĺ÷üĺ", "Ëĺâŕ˙ ęëţ÷čöŕ", "Ďđŕâŕ˙ ęëţ÷čöŕ", "Řĺ˙", "×ĺëţńňü"
};

CMD:aeditskin(playerid)
{
	if(PlayerInfo[playerid][pSoska] < 10) return ErrorMessage(playerid, "{FF6347}Âű íĺ ěîćĺňĺ čńďîëüçîâŕňü ýňó ęîěŕíäó");
	if(AccessoryEditSkin == 0) AccessoryEditSkin = 1, SuccessMessage(playerid, "{99ff66}Đĺäŕęňîđ âęë");
	else AccessoryEditSkin = 0, SuccessMessage(playerid, "{FF6347}Đĺäŕęňîđ âűęë");
	return 1;
}

CMD:accessory(playerid)
{
	if(PlayerInfo[playerid][pSoska] < 10) return ErrorMessage(playerid, "{FF6347}Âű íĺ ěîćĺňĺ čńďîëüçîâŕňü ýňó ęîěŕíäó");
	DP[0][playerid] = 0;
	AccessoryList(playerid, 0, "");
	return 1;
}

stock AccessoryList(playerid, page, const findName[]) // Ěĺíţ íŕńňđîĺę ŕęńĺńńóŕđîâ äë˙ čăđîęîâ
{
    format(ListName[playerid],34, ""); // Î÷čůŕĺě čě˙ ńîőđŕí¸ííîăî ďîčńęŕ
	DP[1][playerid] = page; // Ńîőđŕí˙ĺě îňęđűňóţ ńňđŕíčöó
	DP[2][playerid] = 0; // Ńáđŕńűâŕĺě ńňŕňóń îňîáđŕćĺíč˙ ńďčńęŕ ŕęńĺńńóŕđîâ
	
    new minId = 0, maxId = 99, quanId, quanFind = strlen(findName), quanType, findModel; // Ěčíčěŕëüíűé č ěŕęńčěŕëüíî îňîáđŕćŕĺěűĺ ŕęńĺńńóŕđű íŕ ńňđŕíčöĺ
    if(page >= 1) minId += 100*page, maxId += 100*page; // Ĺńëč ýňî ńëĺäóţůčĺ ńňđŕíčöű, ďđčńâŕčâŕĺě ńëĺäóţůčĺ ID
    
    format(lines,sizeof(lines),""); // Î÷čůŕĺě Lines
	format(line,sizeof(line),"Ŕęńĺńńóŕđ\tModel\tÖĺíŕ"), strcat(lines,line);
	format(line,sizeof(line),"\n{99ff66}Äîáŕâčňü ŕęńĺńńóŕđ\t\t"), strcat(lines,line);
	
	if(quanFind > 0)
	{
	    format(ListName[playerid],34, "%s", findName); // Ńîőđŕí˙ĺě ďîčńę ďî čěĺíč
	    if(IsNumeric(findName)) quanType = 1, findModel = strval(findName);
		format(line,sizeof(line),"\n{cccccc}Íŕéňč [%s]\t\t", findName), strcat(lines,line);
	}
	else format(line,sizeof(line),"\n{cccccc}Íŕéňč\t\t"), strcat(lines,line);
	
    for(new i = minId; i < maxId; i++)
	{
	    if(AccessoryInfo[i][acModel] > 0 && quanFind == 0 // Ĺńëč ďîčńę ďî ěîäĺëč č čěĺíč íĺ ŕęňčâĺí, ďđîńňî ďîęŕçűâŕĺě âńĺ ŕęńĺńńóŕđű
		|| quanFind > 0 && (quanType == 1 && AccessoryInfo[i][acModel] == findModel) // Čůĺě ďî model
		|| quanFind > 0 && (quanType == 0 && strfind(AccessoryInfo[i][acName], findName, true) != -1)) // Čůĺě ďî íŕçâŕíčţ
	    {
	        List[quanId][playerid] = i; // Ńîőđŕí˙ĺě íŕéäĺííűé ŕęńĺńńóŕđ â ďĺđĺěĺííóţ
	        quanId ++; // Âĺä¸ě ďîäń÷¸ň ďĺđĺěĺííűő
			if(AccessoryInfo[i][acStatus] == 0) format(line,sizeof(line),"\n{cccccc}%d. %s\t%d\t%d$", i+1, AccessoryInfo[i][acName], AccessoryInfo[i][acModel], AccessoryInfo[i][acPrice]), strcat(lines,line);
			else format(line,sizeof(line),"\n{cccccc}%d. {ff9000}%s\t{cccccc}%d\t%d$", i+1, AccessoryInfo[i][acName], AccessoryInfo[i][acModel], AccessoryInfo[i][acPrice]), strcat(lines,line);
		}
	}
	if(quanId == 0)
	{
		DP[2][playerid] = 1;
		format(line,sizeof(line),"\n{FF6347}Ŕęńĺńńóŕđű íĺ íŕéäĺíű\t\t"), strcat(lines,line);
	}
	if(page > 0 || quanId >= 100) format(line,sizeof(line),"\n{444444}Äŕëĺĺ >>\t\t"), strcat(lines,line);
	
	new lol[60];
	format(lol,sizeof(lol),"{ff9000}Ŕęńĺńńóŕđű %d {cccccc}[Ńňđŕíčöŕ %d]", AccessoryQuan, page+1);
    ShowDialog(playerid,1278,DIALOG_STYLE_TABLIST_HEADERS,lol,lines,"Âűáđŕňü","Âűőîä");
    return 1;
}

stock AccessorySetting(playerid, i) // Ěĺíţ íŕńňđîéęč ęîíęđĺňíîăî ŕęńĺńńóŕđŕ
{
	if(i == -1)
	{
	    format(store,sizeof(store),"{cccccc}Ââĺäčňĺ ID Model ŕęńĺńńóŕđŕ [321 - %d]\n\n{444444}Âń˙ íĺîáőîäčěŕ˙ číôîđěŕöč˙ îá ŕęńĺńńóŕđŕő č ďîčńęĺ ěîäĺëĺé íŕ ôîđóěĺ", MAX_OBJECT_MODEL_ID);
	    ShowDialog(playerid,1280,DIALOG_STYLE_INPUT,"{ff9000}Ńîçäŕíčĺ Ŕęńĺńńóŕđŕ",store,"Ďđčí˙ňü","Îňěĺíŕ");
	}
	else
	{
	    if(i < 0 || i >= MAX_ACCESSORY) return 1;
	    if(AccessoryInfo[i][acModel] == 0) return 1;
	    DP[3][playerid] = i;
	    
	    
	    format(lines,sizeof(lines),""); // Î÷čůŕĺě Lines
		format(line,sizeof(line),"%d. Model: %d \t", i+1, AccessoryInfo[i][acModel]), strcat(lines,line);
		
		if(AccessoryInfo[i][acStatus] == 0) format(line,sizeof(line),"\n{cccccc}Ńňŕňóń: \t{FF6347}Íĺ ŕęňčâĺí"), strcat(lines,line);
		else format(line,sizeof(line),"\n{cccccc}Ńňŕňóń: \t{99ff66}Ŕęňčâĺí"), strcat(lines,line);
		
		format(line,sizeof(line),"\n{cccccc}Íŕçâŕíčĺ: \t{ff9000}%s", AccessoryInfo[i][acName]), strcat(lines,line);
		format(line,sizeof(line),"\n{cccccc}Ăîń. Ńňîčěîńňü: \t{99ff66}%d$ [%s]", AccessoryInfo[i][acPrice], get_k(AccessoryInfo[i][acPrice])), strcat(lines,line);
		format(line,sizeof(line),"\n{cccccc}Ęîńňü ęđĺďëĺíč˙: \t{444444}%s", boneName[AccessoryInfo[i][acBone]]), strcat(lines,line);
		format(line,sizeof(line),"\n{444444}Đŕńďîëîćĺíčĺ íŕ čăđîęĺ >> \t"), strcat(lines,line);
		format(line,sizeof(line),"\n{444444}Îňîáđŕćĺíčĺ â ňĺęńňäđŕâĺ >> \t"), strcat(lines,line);
		format(line,sizeof(line),"\n{FF6347}Óäŕëčňü ŕęńĺńńóŕđ \t"), strcat(lines,line);
		
	    ShowDialog(playerid,1281,DIALOG_STYLE_TABLIST_HEADERS,"{ff9000}Ŕęńĺńńóŕđ",lines,"Âűáđŕňü","Íŕçŕä");
	}
	return 1;
}

stock CreateAccessory(modelId, stat, boneId) // Äîáŕâëĺíčĺ íîâîăî ŕęńĺńńóŕđŕ
{
	new accId = -1;
	
	//=====
	// Äîáŕâëĺíčĺ ďđč íŕäĺâŕíčč, ńëĺäîâŕňĺëüíî - ńíŕ÷ŕëŕ ďđîâĺđ˙ĺě íŕ íŕëč÷čĺ ňŕęîăî ŕęńĺńńóŕđŕ â ńďčńęĺ
	// Ýňî âđĺěĺííűé ôóíęöčîíŕë, íóćĺí äë˙ äîáŕâëĺíč˙ ŕęńĺńńóŕđîâ ńňŕđîăî ňčďŕ čăđîęŕěč č ňĺńňĺđŕěč áĺç ó÷ŕńňč˙ đŕçđŕáîâ. Â áóäóůĺě ĺăî ěîćíî áóäĺň ÂŰĐĹÇŔŇÜ
	new bool:isAvailable;
	if(stat == 1)
	{
	    for(new i = 0; i < MAX_ACCESSORY; i++)
		{
		    if(AccessoryInfo[i][acModel] == modelId && AccessoryInfo[i][acBone] == boneId)
		    {
                isAvailable = true;
                break;
		    }
  		}
  		if(isAvailable) return accId;
	}
	//=====

	for(new i = 0; i < MAX_ACCESSORY; i++)
	{
	    if(AccessoryInfo[i][acModel] == 0) // Íŕőîäčě ďóńňîé ńëîň č ńîçäŕ¸ě ŕęńĺńńóŕđ ňóäŕ
	    {
	        AccessoryInfo[i][acModel] = modelId; // Çŕďčńűâŕĺě ěîäĺëü
	        format(AccessoryInfo[i][acName], 34, "%s", thing_name(modelId)); // Ďîëó÷ŕĺě čě˙ čç ńňŕđîăî ńďčńęŕ čě¸í ŕęńĺńńóŕđîâ
	        AccessoryInfo[i][acPrice] = 10000; // Çŕďčńűâŕĺě äĺôîëňíóţ ńňîčěîńňü
	        AccessoryInfo[i][acStatus] = stat; // Óńňŕíŕâëčâŕĺě ńňŕňóń
	        
	        // Ďîëó÷ŕĺě đŕńďîëîćĺíčĺ íŕ čăđîęĺ č ęîńňü čç ńňŕđîăî ńďčńęŕ
	        thing(modelId, AccessoryInfo[i][acX], AccessoryInfo[i][acY], AccessoryInfo[i][acZ], AccessoryInfo[i][acrX], AccessoryInfo[i][acrY], AccessoryInfo[i][acrZ], AccessoryInfo[i][acsX], AccessoryInfo[i][acsY], AccessoryInfo[i][acsZ], AccessoryInfo[i][acBone]);

            AccessoryQuan ++;
            SaveAccessory(i, 0); // Ńîçäŕ¸ě íîâóţ ńňđîęó â áŕçó
            
            accId = i;
	        break;
	    }
 	}
	return accId;
}

stock SaveAccessory(i, stat) // Îáíîâë˙ĺě čëč äîáŕâë˙ĺě ńňđîęó îá ŕęńĺńńóŕđĺ
{
	new send_name[34];
    mysql_escape_string(AccessoryInfo[i][acName], send_name, sizeof(send_name));
    
    if(stat == 1) format(big_query, sizeof(big_query), "UPDATE");
    else format(big_query, sizeof(big_query), "INSERT INTO");

	format(big_query, sizeof(big_query), "%s `accessory` SET `acModel`='%d',`acName`='%s',`acPrice`='%d',`acStatus`='%d',`acBone`='%d'",big_query,
	AccessoryInfo[i][acModel], send_name, AccessoryInfo[i][acPrice], AccessoryInfo[i][acStatus], AccessoryInfo[i][acBone]);
	
	format(big_query,sizeof(big_query),"%s, `acX` = '%f', `acY` = '%f', `acZ` = '%f', `acrX` = '%f', `acrY` = '%f', `acrZ` = '%f',\
	`acsX` = '%f', `acsY` = '%f', `acsZ` = '%f'", big_query,
	AccessoryInfo[i][acX],AccessoryInfo[i][acY],AccessoryInfo[i][acZ],AccessoryInfo[i][acrX],AccessoryInfo[i][acrY],AccessoryInfo[i][acrZ],
	AccessoryInfo[i][acsX],AccessoryInfo[i][acsY],AccessoryInfo[i][acsZ]);
	
	if(stat == 1) format(big_query, sizeof(big_query), "%s  WHERE `newid` = '%d'", big_query, AccessoryInfo[i][acID]);
	query_empty(pearsq, big_query);
	
	if(stat == 0) AccessoryInfo[i][acID] = cache_insert_id();
	
	AccessoryInfo[i][acMysqlCheck] = false;
    return 1;
}

stock GetNameAccessory(modelId)
{
	new findSlot = -1, send_name[34];
    for(new i = 0; i < MAX_ACCESSORY; i++)
	{
	    if(AccessoryInfo[i][acModel] == modelId)
	    {
	        findSlot = i;
            break;
	    }
	}
	if(findSlot >= 0) format(send_name, 34, "%s", AccessoryInfo[findSlot][acName]);
	else format(send_name, 34, "%s", thing_name(modelId));
	
	return send_name;
}

stock GetTextDrawNameAccessory(modelId)
{
	new findSlot = -1, send_name[34];
    for(new i = 0; i < MAX_ACCESSORY; i++)
	{
	    if(AccessoryInfo[i][acModel] == modelId)
	    {
	        findSlot = i;
            break;
	    }
	}
	if(findSlot >= 0) format(send_name, 34, RusToGame("%s"), AccessoryInfo[findSlot][acName]);
	else format(send_name, 34, "%s", thing_namedraw(modelId));

	return send_name;
}

stock DeleteAccessory(i)
{
	format(store,sizeof(store),"DELETE FROM `accessory` WHERE `newid` = '%d'", AccessoryInfo[i][acID]);
	query_empty(pearsq, store);
	AccessoryInfo[i][acMysqlCheck] = false;
	
	AccessoryInfo[i][acModel] = 0;
    format(AccessoryInfo[i][acName], 34, "");
    AccessoryInfo[i][acPrice] = 0;
    AccessoryInfo[i][acStatus] = 0;

    AccessoryInfo[i][acX] = 0, AccessoryInfo[i][acY] = 0, AccessoryInfo[i][acZ] = 0, AccessoryInfo[i][acrX] = 0, AccessoryInfo[i][acrY] = 0, AccessoryInfo[i][acrZ] = 0, AccessoryInfo[i][acsX] = 0, AccessoryInfo[i][acsY] = 0, AccessoryInfo[i][acsZ] = 0, AccessoryInfo[i][acBone] = 0;

    AccessoryInfo[i][acUpdate] = false;
    AccessoryQuan --;
	return 1;
}

forward LoadAccessory(); // Çŕăđóçęŕ ŕęńĺńńóŕđîâ čç áŕçű
public LoadAccessory()
{
	new rows, time = GetTickCount();
	cache_get_row_count(rows);
	for(new f; f < rows; ++f)
	{
    	cache_get_value_name_int(f, "newid", AccessoryInfo[f][acID]);
    	cache_get_value_name_int(f, "acModel", AccessoryInfo[f][acModel]);
    	cache_get_value_name(f, "acName", AccessoryInfo[f][acName], 34);
    	cache_get_value_name_int(f, "acPrice", AccessoryInfo[f][acPrice]);
    	cache_get_value_name_int(f, "acStatus", AccessoryInfo[f][acStatus]);
    	cache_get_value_name_int(f, "acBone", AccessoryInfo[f][acBone]);
		cache_get_value_name_float(f, "acX", AccessoryInfo[f][acX]);
		cache_get_value_name_float(f, "acY", AccessoryInfo[f][acY]);
		cache_get_value_name_float(f, "acZ", AccessoryInfo[f][acZ]);
		cache_get_value_name_float(f, "acrX", AccessoryInfo[f][acrX]);
		cache_get_value_name_float(f, "acrY", AccessoryInfo[f][acrY]);
		cache_get_value_name_float(f, "acrZ", AccessoryInfo[f][acrZ]);
		cache_get_value_name_float(f, "acsX", AccessoryInfo[f][acsX]);
		cache_get_value_name_float(f, "acsY", AccessoryInfo[f][acsY]);
		cache_get_value_name_float(f, "acsZ", AccessoryInfo[f][acsZ]);
		AccessoryQuan ++;
	}
	printf("[MODE]: Ŕęńĺńńóŕđű [%d Quan][%d ms]",rows, GetTickCount() - time);
	return 1;
}
