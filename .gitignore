# Ignore everything
*
!*/

# And then exclude required files

# Pwn and inc files (gamemode, filterscripts, npcmodes etc)
!gamemodes/**/*.pwn
!gamemodes/**/*.inc
!filterscripts/*.pwn
!npcmodes/*.pwn

# NPCs recordings
!npcmodes/recordings/*.rec

# Some custom files required for gamemode
!scriptfiles

# Proper files encoding detection & diff decorations disable
!.vscode/settings.json
